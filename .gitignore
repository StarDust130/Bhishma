# Vercel / Now / Netlify
.vercel/
.vercel_build_output/
.now
.now__logs
.netlify/

# Environment files (keep secrets out of repo)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# TypeScript
*.tsbuildinfo

# Dependency managers / package managers
.pnp/
.pnp.js
.yarn/*
!.yarn/patches
!.yarn/releases
!.yarn/plugins
!.yarn/sdks
!.yarn/versions
.yarn-integrity
pnpm-lock.yaml

# IDEs and editors
.vscode/
.idea/
*.sublime-*
*.code-workspace

# OS generated files
.DS_Store
Thumbs.db
desktop.ini

