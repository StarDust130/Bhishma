logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Testing / coverage
coverage/
.nyc_output/

# Build / output
dist/
build/
out/
.tmp/
.temp/
.turbo/

# Next.js
.next/
.next/cache/
out/
