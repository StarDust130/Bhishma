# .dockerignore — reduce Docker build context

# Exclude VCS
.git
.gitignore

# Node/pnpm artifacts
node_modules
node_modules/
.pnpm-store
node_modules/.pnpm
.pnpm-debug.log*

# Logs
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
*.log

# Env & local config
.env
.env.local
.env.*.local
.env.production
.env.production.local

# Build outputs
.next
.next/
.next/cache
out
dist
build
.tmp
.temp
.turbo

# Editor/IDE
.vscode
.idea
*.code-workspace

# OS & misc
.DS_Store
Thumbs.db
desktop.ini
tmp
temp
.cache
.sass-cache
.parcel-cache

# Deploy / hosting
.vercel
.vercel_build_output
.now
.now__logs
.netlify

# Docker / compose overrides
docker-compose.override.yml

# Secrets & keys
*.pem
*.key
*.crt

# Misc
uploads/
*.tgz
*.gz
*.zip

# Keep package and lockfiles, workspace config, and Dockerfile in context
!package.json
!package-lock.json
!pnpm-lock.yaml
!yarn.lock
!pnpm-workspace.yaml
!Dockerfile
!.dockerignore
